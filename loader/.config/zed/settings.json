// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "diagnostics": {
    "inline": {
      "enabled": true
    }
  },
  "diff_view_style": "split",
  "git": {
    "path_style": "file_path_first",
    "hunk_style": "unstaged_hollow"
  },
  "title_bar": {
    "show_menus": false,
    "show_user_picture": true,
    "show_user_menu": true,
    "show_sign_in": true,
    "show_project_items": true,
    "show_branch_icon": true
  },
  "file_finder": {
    "modal_max_width": "medium"
  },
  "search_wrap": false,
  "colorize_brackets": true,
  "inlay_hints": {
    "enabled": true
  },
  "vim": {
    "toggle_relative_line_numbers": true
  },
  "gutter": {
    "min_line_number_digits": 2
  },
  "relative_line_numbers": "disabled",
  "sticky_scroll": {
    "enabled": true
  },
  "which_key": {
    "enabled": true
  },
  "tab_bar": {
    "show_tab_bar_buttons": true,
    "show_nav_history_buttons": false,
    "show_pinned_tabs_in_separate_row": true
  },
  "format_on_save": "off",
  "buffer_line_height": "comfortable",
  "buffer_font_size": 16.0,
  "disable_ai": true,
  "debugger": {
    "dock": "right",
  },
  "agent": {
    "dock": "left",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "diff_stats": true,
    "default_width": 240.0,
    "sort_by_path": true,
    "collapse_untracked_diff": false,
    "status_style": "label_color",
    "tree_view": false,
    "dock": "right",
  },
  "outline_panel": {
    "dock": "right",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "unnecessary_code_fade": 0.4,
  "terminal": {
    "dock": "bottom",
    "font_family": "FiraCode Nerd Font Mono",
    "font_fallbacks": ["FiraCode Nerd Font"],
    "blinking": "on",
    "copy_on_select": true,
  },
  "project_panel": {
    "default_width": 240.0,
    "hide_hidden": false,
    "diagnostic_badges": false,
    "bold_folder_labels": true,
    "git_status": true,
    "dock": "right",
    "auto_fold_dirs": true,
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false,
  },
  "tabs": {
    "show_diagnostics": "errors",
    "file_icons": true,
    "git_status": true,
    "show_close_button": "hidden",
  },
  "minimap": {
    "display_in": "active_editor",
    "show": "auto",
    "thumb": "always",
  },
  "cursor_blink": true,
  "buffer_font_fallbacks": ["FiraCode Nerd Font"],
  "buffer_font_family": "FiraMono Nerd Font",
  "file_types": {
    "tailwindcss": ["*.css"],
    "editorconfig": ["*.toml"],
    "dotenv": [".env*", "config"],
    "properties": ["*.env"],
  },
  "show_whitespaces": "boundary",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [100, 120],
  "tab_size": 2,
  "icon_theme": "Zed (Default)",
  "ui_font_size": 16,
  "theme": "Nord Dark",
}
