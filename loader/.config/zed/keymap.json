// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-u": "editor::ConvertToUpperCase",
      "ctrl-shift-l": "editor::ConvertToLowerCase",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-tab": "pane::ActivateNextItem",
    }
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-enter": "workspace::ZoomIn",
      "cmd-shift-enter": "workspace::ZoomOut",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "shift shift": "file_finder::Toggle",
      "f1": "command_palette::Toggle",
      // dock
      "secondary-alt-b": "workspace::ToggleLeftDock",
      "secondary-b": "workspace::ToggleRightDock",
      // panels
      "ctrl-alt-a": "agent::Toggle",
      "ctrl-alt-e": "project_panel::Toggle",
      "ctrl-alt-g": "git_panel::Toggle",
      "ctrl-alt-t": "terminal_panel::Toggle",
      "ctrl-§": "terminal_panel::Toggle",
      // git
      "ctrl-g ctrl-g": ["task::Spawn", { "task_name": "lazygit", "reveal_target": "center" }],
      "ctrl-g ctrl-t": "git_graph::Open",
    },
  },
]
