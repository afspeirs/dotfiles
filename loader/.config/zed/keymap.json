// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor",
    "bindings": {
      "ctrl-shift-u": "editor::ConvertToUpperCase",
      "ctrl-shift-l": "editor::ConvertToLowerCase",
      "ctrl-shift-o": "editor::OrganizeImports",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "cmd-enter": "workspace::ZoomIn",
      "cmd-shift-enter": "workspace::ZoomOut",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "f1": "command_palette::Toggle",
      "ctrl-§": "terminal_panel::Toggle",
      "alt-cmd-b": "workspace::ToggleLeftDock",
      "cmd-b": "workspace::ToggleRightDock",
      "cmd-e": "project_panel::ToggleFocus",
      "cmd-g": "git_panel::ToggleFocus",
    },
  },
]
